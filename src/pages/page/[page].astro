---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import PostMasonry from "../../components/PostMasonry.astro";

export async function getStaticPaths({ paginate }: any) {
	const PAGE_SIZE = 10;
	let posts = (await getCollection("blog")).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);

	posts = posts.filter((post) => post.data.tags && post.data.tags.length > 0);

	return paginate(posts, { pageSize: PAGE_SIZE });
}

const { page } = Astro.props as any;

const fixedUrl = {
	...page.url,
	first: "/",
	prev: page.currentPage === 2 ? "/" : page.url.prev,
	last: page.lastPage > 1 ? `/page/${page.lastPage}` : undefined,
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`${SITE_TITLE} - Page ${page.currentPage}`}
			description={SITE_DESCRIPTION}
		/>
		<style>
			main {
				width: 960px;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section>
				<PostMasonry
					posts={page.data}
					page={{ ...page, url: fixedUrl }}
				/>
			</section>
		</main>

		<Footer />
	</body>
</html>
