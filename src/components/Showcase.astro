---
type ShowcaseItem = {
	href: string;
	title: string;
	description?: string;
	ariaLabel?: string;
	iconSrc: string;
	iconAlt?: string;
};

const items: ShowcaseItem[] = [
	{
		href: "https://x.p1gd0g.cc",
		title: "Gridder",
		description: "网格交易测试工具",
		ariaLabel: "Gridder",
		iconSrc: "/icon/gridder.png",
		iconAlt: "Gridder 图标",
	},
	{
		href: "https://y.p1gd0g.cc",
		title: "ATRx",
		description: "ETF 波动率对比",
		ariaLabel: "ATRx",
		iconSrc: "/icon/atrx.png",
		iconAlt: "ATRx 图标",
	},
	{
		href: "https://u.p1gd0g.cc",
		title: "USDer",
		description: "美元/人民币理财对比",
		ariaLabel: "USDer",
		iconSrc: "/icon/usder.png",
		iconAlt: "USDer 图标",
	},
	{
		href: "https://t.p1gd0g.cc",
		title: "Since Then",
		description: "计时器",
		ariaLabel: "Since Then",
		iconSrc: "/icon/since-then-timer.png",
		iconAlt: "Since Then 图标",
	},
	{
		href: "https://z.p1gd0g.cc",
		title: "Martin Calc",
		description: "Martin Calc 马丁格尔计算器",
		ariaLabel: "Martin Calc",
		iconSrc: "/icon/martin-calc.png",
		iconAlt: "Martin Calc 图标",
	},
	{
		href: "https://m.p1gd0g.cc",
		title: "韭花",
		description: "电影点映评分",
		ariaLabel: "韭花",
		iconSrc: "/icon/leak-flower.png",
		iconAlt: "韭花 图标",
	},
];
---

<section class="showcase" aria-label="Showcase">
	<div class="viewport">
		<button class="nav left" type="button" aria-label="向左滚动" data-dir="-1">
			<span aria-hidden="true">‹</span>
		</button>
		<button class="nav right" type="button" aria-label="向右滚动" data-dir="1">
			<span aria-hidden="true">›</span>
		</button>

		<div class="track" role="list">
		{
			items.map((item) => (
				<a
					class="card"
					role="listitem"
					href={item.href}
					target="_blank"
					rel="noopener noreferrer"
					title={item.title}
					aria-label={item.ariaLabel ?? item.title}
				>
					<span class="icon">
						<img
							src={item.iconSrc}
							width={77}
							height={77}
							alt={item.iconAlt ?? item.title}
							loading="lazy"
							decoding="async"
						/>
					</span>
					<span class="title">{item.title}</span>
					<span class="description">{item.description}</span>
				</a>
			))
		}
	</div>
	</div>
</section>

<style>
	.showcase {
		--card-bg: rgba(var(--gray-light), 0.55);
		--card-bg-hover: rgba(var(--gray-light), 0.75);
		--card-border: rgba(var(--gray), 0.22);
		--text: rgb(var(--black));
		--muted: rgb(var(--gray-dark));
		margin: 0;
	}

	.viewport {
		position: relative;
	}

	.track {
		display: flex;
		gap: 12px;
		padding: 8px 6px;
		margin: 0 -6px;
		overflow-x: auto;
		overflow-y: hidden;
		-webkit-overflow-scrolling: touch;
		scroll-snap-type: x mandatory;
		scroll-padding: 6px;
		background: transparent;

		/* hide scrollbar but keep scrolling */
		scrollbar-width: none; /* Firefox */
		-ms-overflow-style: none; /* IE/Edge Legacy */
	}

	.track::-webkit-scrollbar {
		display: none; /* Chrome/Safari */
	}

	.nav {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		z-index: 2;
		width: 36px;
		height: 36px;
		border-radius: 999px;
		border: 1px solid rgba(var(--gray), 0.25);
		background: rgba(255, 255, 255, 0.9);
		box-shadow: 0 6px 18px rgba(var(--gray), 0.25);
		color: rgb(var(--gray-dark));
		display: grid;
		place-items: center;
		cursor: pointer;
		user-select: none;
		transition:
			transform 160ms ease,
			opacity 160ms ease,
			background-color 160ms ease,
			border-color 160ms ease;
	}

	.nav span {
		font-size: 22px;
		line-height: 1;
	}

	.nav:hover {
		border-color: rgba(var(--gray), 0.45);
		background: rgba(255, 255, 255, 0.98);
	}

	.nav:active {
		transform: translateY(-50%) scale(0.98);
	}

	.nav:focus-visible {
		outline: 3px solid var(--accent);
		outline-offset: 3px;
	}

	.nav[disabled] {
		opacity: 0.35;
		cursor: default;
	}

	.nav.left {
		left: -10px;
	}
	.nav.right {
		right: -10px;
	}

	.card {
		scroll-snap-align: start;
		flex: 0 0 auto;
		width: 144px;
		height: 188px;

		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 12px;

		padding: 12px 14px;
		border-radius: 14px;
		border: 1px solid var(--card-border);
		background: var(--card-bg);
		color: var(--text);
		text-decoration: none;

		/* box-shadow: var(--box-shadow); */
		transition:
			transform 160ms ease,
			box-shadow 160ms ease,
			border-color 160ms ease,
			background-color 160ms ease;
	}

	.card:hover {
		transform: translateY(-2px);
		border-color: rgba(var(--gray), 0.38);
		background: var(--card-bg-hover);
	}

	.card:active {
		transform: translateY(0);
	}

	.card:focus-visible {
		outline: 3px solid var(--accent);
		outline-offset: 3px;
	}

	.icon {
		width: 88px;
		height: 88px;
		border-radius: 12px;
		display: grid;
		place-items: center;
		/* background: rgba(var(--gray), 0.12);
		border: 1px solid rgba(var(--gray), 0.22); */
		flex: 0 0 auto;
	}

	.icon img {
		display: block;
	}

	.title {
		font-size: 1.2rem;
		line-height: 1.25;
		color: var(--muted);
		font-weight: 600;
		white-space: normal;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.description {
		font-size: 0.8rem;
		line-height: 1.25;
		color: var(--muted);
		white-space: normal;
	}


	.card:hover .title {
		color: rgb(var(--black));
	}

	@media (max-width: 720px) {
		.card {
			width: 142px;
			height: 198px;
			padding: 11px 12px;
			border-radius: 13px;
		}
		.title {
			font-size: 0.95rem;
		}
		
	}
</style>

<script>
	// @ts-nocheck
	function setupShowcase(root) {
		const track = root.querySelector(".track");
		const buttons = root.querySelectorAll("button.nav");

		if (!track || buttons.length === 0) return;

		function updateNavState() {
			const maxScrollLeft = track.scrollWidth - track.clientWidth;
			const atStart = track.scrollLeft <= 1;
			const atEnd = track.scrollLeft >= maxScrollLeft - 1;
			for (const btn of buttons) {
				const dir = Number(btn.getAttribute("data-dir") || "0");
				if (dir < 0) btn.toggleAttribute("disabled", atStart);
				if (dir > 0) btn.toggleAttribute("disabled", atEnd);
			}
		}

		function getStep() {
			const first = track.querySelector(".card");
			if (!first) return Math.max(220, track.clientWidth * 0.8);
			const cardRect = first.getBoundingClientRect();
			const gap = 12;
			return Math.max(180, Math.round(cardRect.width + gap) * 2);
		}

		for (const btn of buttons) {
			btn.addEventListener("click", () => {
				if (btn.hasAttribute("disabled")) return;
				const dir = Number(btn.getAttribute("data-dir") || "0");
				track.scrollBy({ left: dir * getStep(), behavior: "smooth" });
			});
		}

		track.addEventListener("scroll", updateNavState, { passive: true });
		window.addEventListener("resize", updateNavState);
		updateNavState();
	}

	for (const root of document.querySelectorAll(".showcase")) {
		setupShowcase(root);
	}
</script>
